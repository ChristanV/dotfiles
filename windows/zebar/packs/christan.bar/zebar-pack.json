{
  "name": "christan-bar",
  "description": "Solarized dark bar matching Waybar layout",
  "tags": ["bar"],
  "version": "1.0.0",
  "widgets": {
    "top-bar": {
      "template": "top-bar/index.html",
      "defaultPreset": "default",
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "50px",
          "zOrder": "always_on_top",
          "shownInTaskbar": false,
          "focused": false,
          "resizable": false,
          "transparent": true
        }
      ]
    }
  }
}
