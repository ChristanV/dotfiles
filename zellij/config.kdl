default_shell "zsh"

default_layout "default"

theme "nord-blue"

themes {
    nord-blue {
        fg "#d8dee9"
        bg "#2e3440"
        black "#3b4252"
        red "#bf616a"
        green "#769ff0"
        yellow "#ebcb8b"
        blue "#81a1c1"
        magenta "#b48ead"
        cyan "#88c0d0"
        white "#e5e9f0"
        orange "#d08770"
    }
}

simplified_ui false

pane_frames false

copy_command "wl-copy"
copy_on_select true

mouse_mode true
mouse_hover_effect true
focus_follows_mouse false
scroll_buffer_size 10000

show_startup_tips false
show_release_notes false

keybinds {
    unbind "Ctrl r"

    shared_except "locked" {
        // Splits (panes)
        bind "Alt n" { NewPane "Right"; }
        bind "Alt m" { NewPane "Down"; }

        // Tabs
        bind "Alt r" { NewTab; }

        // Navigation
        bind "Alt o" { SwitchFocus; }
        bind "Alt l" { GoToNextTab; }
        bind "Alt h" { GoToPreviousTab; }

        // Pane cycling (works in floating mode too)
        bind "Alt Left" { MoveFocus "Left"; }
        bind "Alt Right" { MoveFocus "Right"; }
        bind "Alt Up" { MoveFocus "Up"; }
        bind "Alt Down" { MoveFocus "Down"; }

        // Close / quit
        bind "Alt w" { CloseFocus; }
        bind "Alt q" { Quit; }

        // Pane resizing
        bind "Alt h" { Resize "Left"; }
        bind "Alt j" { Resize "Down"; }
        bind "Alt k" { Resize "Up"; }
        bind "Alt l" { Resize "Right"; }

        // Toggle fullscreen on focused pane
        bind "Alt t" { ToggleFocusFullscreen; }

        // Toggle floating panes
        bind "Alt f" { ToggleFloatingPanes; }

        // Jump to tab by number
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
    }
}

ui {
    pane_frames {
        rounded_corners true
        hide_session_name true
    }
}

